<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.StartupActivity">

    <Button
        android:id="@+id/UserPhoneButton"
        android:layout_width="223dp"
        android:layout_height="92dp"
        android:layout_marginTop="112dp"
        android:layout_marginEnd="82dp"
        android:layout_marginBottom="89dp"
        android:text="User Phone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/PhoneSelectionMessage" />

    <Button
        android:id="@+id/DronePhoneButton"
        android:layout_width="223dp"
        android:layout_height="92dp"
        android:layout_marginStart="82dp"
        android:layout_marginTop="112dp"
        android:layout_marginBottom="89dp"
        android:text="Drone Phone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/PhoneSelectionMessage" />

    <TextView
        android:id="@+id/PhoneSelectionMessage"
        android:layout_width="388dp"
        android:layout_height="45dp"
        android:layout_marginStart="208dp"
        android:layout_marginTop="87dp"
        android:layout_marginEnd="209dp"
        android:text="Please Select Phone Type"
        android:textSize="34sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/exitButton"
        android:layout_width="71dp"
        android:layout_height="54dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="71dp"
        android:layout_height="54dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:clickable="false"
        android:elevation="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_close_clear_cancel" />
</androidx.constraintlayout.widget.ConstraintLayout>